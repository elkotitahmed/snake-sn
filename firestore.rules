rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - highScore: number (required)
    //   - selectedSkinId: string (required)
    //   - updatedAt: timestamp (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'highScore', 'selectedSkinId']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.highScore is number &&
             data.selectedSkinId is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
