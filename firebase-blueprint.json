{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user game data and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "highScore": { "type": "number", "description": "All-time high score" },
        "selectedSkinId": { "type": "string", "description": "ID of the currently selected skin" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "highScore", "selectedSkinId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    }
  }
}
